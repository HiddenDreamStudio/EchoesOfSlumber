{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/bin/Debug/EchoesOfSlumber.exe",
      "args": [
        "-r",
        "-w",
        "Debug"
      ],
      "cwd": "${workspaceFolder}/bin/Debug"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "c:/Users/aidan/Documents/GitHub/EchoesOfSlumber",
      "program": "c:/Users/aidan/Documents/GitHub/EchoesOfSlumber/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}